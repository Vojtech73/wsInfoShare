# Skopiuj ten plik jako .env.production na serwerze i uzupełnij wartości
# NIE commituj .env.production do repozytorium

# Django
SECRET_KEY=zmien-na-silny-losowy-klucz-min-50-znakow
DEBUG=False
ALLOWED_HOSTS=ws-infoshare.twoja-domena.pl
CSRF_TRUSTED_ORIGINS=https://ws-infoshare.twoja-domena.pl
DJANGO_SETTINGS_MODULE=config.settings

# Baza danych — dopasuj do konfiguracji PostgreSQL w docker-compose.yml
DATABASE_URL=postgresql://ws_info_share:twoje-haslo-postgres@db:5432/ws_info_share

# PostgreSQL — używane przez kontener db w docker-compose.yml
POSTGRES_DB=ws_info_share
POSTGRES_USER=ws_info_share
POSTGRES_PASSWORD=twoje-haslo-postgres
